{
  "name": "liminal-natsec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.38",
  "scripts": {
    "install": "node scripts/check-runtime.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:smoke": "node scripts/run-tests.mjs",
    "test:spine": "node --experimental-strip-types --test tests/graph-spine.test.ts",
    "test:all": "node scripts/run-tests.mjs",
    "foundry:ontology:plan": "node scripts/generate-seaforge-ontology-import.mjs --plan-only",
    "foundry:ontology:generate": "node scripts/generate-seaforge-ontology-import.mjs",
    "foundry:ontology:live": "node scripts/generate-seaforge-ontology-import.mjs --live",
    "foundry:ontology:validate": "node scripts/generate-seaforge-ontology-import.mjs --validate",
    "dev:server": "node scripts/dev-entry.mjs server",
    "dev:app": "node scripts/dev-entry.mjs app",
    "dev:desktop": "node scripts/dev-entry.mjs desktop",
    "dev": "node scripts/dev-all.mjs",
    "build": "node scripts/build-available.mjs",
    "export:html": "node scripts/export-html/run.mjs",
    "postinstall:electron": "cd electron && bun install"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=22.6"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
